---
import style from "./style.module.css"; 
---

<footer class={`${style.container} section`}>
    <div class="delimiter">
        <div class={style.subcontainer}>
            <div class={style.brand}>
                <div class={style.logoWrapper}>
                    <img src="/assets/brand/isologo.svg" alt="Cswap Logo" class={style.logo} />
                </div>
                <p class={style.brandDescription}>
                    Soluciones digitales de alto impacto. Diseño estratégico y desarrollo profesional enfocado en resultados.
                </p>
            </div>

            <div class={style.column}>
                <span class={style.columnTitle}>Navegación</span>
                <nav class={style.links}>
                    <a href="#inicio">Inicio</a>
                    <a href="#servicios">Soluciones</a>
                    <a href="#servicios-detalle">Servicios</a>
                    <a href="#nosotros">Nosotros</a>
                    <a href="#proyectos">Proyectos</a>
                </nav>
            </div>

            <div class={style.column}>
                <span class={style.columnTitle}>Contacto</span>
                <div class={style.links}>
                    <a href="mailto:dev.cswap@gmail.com">dev.cswap@gmail.com</a>
                    <a href="https://wa.me/+543516135462">+54 351 613-5462</a>
                    <a href="https://www.instagram.com/coo.swap" target="_blank">@coo.swap</a>
                    <p>Córdoba, Argentina</p>
                </div>
            </div>
        </div>

        <div class={style.footerBottom}>
            <span>&copy; {new Date().getFullYear()} Cswap. Todos los derechos reservados.</span>
        </div>
    </div>
</footer>
