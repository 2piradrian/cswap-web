---
import MediumTitle from "../../components/medium-title/MediumTitle.astro";
import ServiceOfferCard from "../../components/service-offer-card/ServiceOfferCard.astro";
import style from "./style.module.css";
---

<section class={`${style.container} section`} id="precios">
    <div class="delimiter">
        <div class={style.header}>
            <MediumTitle title="Nuestros Servicios" />
            <p class={style.subtitle}>Soluciones escalables adaptadas a tus necesidades de negocio.</p>
        </div>
        
        <div class={style.grid}>
            <ServiceOfferCard 
                title="Desarrollo Web" 
                description="Presencia digital sólida"
                features={["Presencia profesional y escalable", "Autogestión total de contenidos", "Mayor visibilidad en Google", "Carga ultra rápida para tus usuarios"]} 
            />
            <ServiceOfferCard 
                title="Aplicaciones Mobile" 
                description="Tu negocio en el bolsillo"
                features={["Alcance directo a tus clientes", "Experiencia fluida y moderna", "Disponibilidad en tiendas oficiales", "Conexión constante con tu audiencia"]} 
            />
            <ServiceOfferCard 
                title="Sistemas a Medida" 
                description="Eficiencia operativa"
                features={["Optimización de procesos internos", "Información clave en tiempo real", "Soluciones que crecen con tu empresa", "Seguridad y soporte garantizado"]} 
            />
            <ServiceOfferCard 
                title="Diseño UX/UI" 
                description="Experiencias memorables"
                features={["Interfaces intuitivas y fáciles de usar", "Mejora en la tasa de conversión", "Validación con objetivos de negocio", "Diseño centrado en el usuario"]} 
            />
            <ServiceOfferCard 
                title="Identidad Visual" 
                description="Marca con impacto"
                features={["Marca con personalidad única", "Coherencia en todos tus canales", "Diferenciación de la competencia", "Material listo para usar y redes"]} 
            />
            <ServiceOfferCard 
                title="Consultoría IT" 
                description="Estrategia tecnológica"
                features={["Estrategia técnica para tu negocio", "Diagnóstico y mejora de sistemas", "Reducción de costos operativos", "Planificación de infraestructura"]} 
            />
        </div>
    </div>
</section>